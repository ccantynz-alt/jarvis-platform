[Unit]
Description=Jarvis on-box fleet health probe → memory
After=network.target jarvis-memory.service

[Service]
Type=oneshot
ExecStart=/opt/jarvis/scripts/fleet-check.sh
WorkingDirectory=/opt/jarvis

# Rule 4 safety net (2026-07-20) — see jarvis-memory.service for rationale.
MemoryMax=512M
CPUQuota=100%
