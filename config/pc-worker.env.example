# Copy to config/pc-worker.env (gitignored — holds a real bearer token).
# Craig gets JARVIS_WORKER_TOKEN from Jarvis (matches JARVIS_WORKER_TOKEN in
# the server's config/secrets.env — ask Jarvis to generate + set both sides).

JARVIS_GATEWAY_URL=https://jarvis.tailbd6217.ts.net:8443
JARVIS_WORKER_TOKEN=
WORKER_ID=pc-craig
WORKSPACE_ROOT=C:\dev
POLL_MS=10000
HEARTBEAT_MS=30000
TIMEOUT_MIN=30
