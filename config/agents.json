    "kind": "role",
    "runtime": "claude",
    "model": "sonnet",
    "reports_to": "ceo",
    "priority": 5,
    "concurrency": 1,
    "budget": { "max_jobs_per_day": 2, "timeout_min": 20 },
    "permissions": { "cwd": "/opt/jarvis/reports/agents", "may_dispatch": false, "may_push": false },
    "escalation": "reports_to",
    "status": "active"
  },
