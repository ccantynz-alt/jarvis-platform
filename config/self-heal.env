# Jarvis self-heal controller config. Flip SELF_HEAL_MODE and `systemctl restart
# jarvis-self-heal.timer` (or just wait for the next tick — the value is read per run).
#   off      = kill switch (detect nothing, do nothing)
#   dry-run  = detect + notify what it WOULD do, never dispatch
#   live     = actually dispatch repairs
SELF_HEAL_MODE=live

# Guardrails (conservative defaults; all automatic, none block on a human).
# WARNING: systemd EnvironmentFile does NOT strip inline comments — a comment on
# the same line becomes part of the value, Number() turns it into NaN, and every
# guardrail comparison silently disables (this happened 2026-07-17: 117 dispatches
# in a day against a cap of 6). Comments live on their OWN lines here, always.
# site must be down this long before acting (survives a flap):
SELF_HEAL_DOWN_MINUTES=12
# no re-attempt on the same platform within this window (minutes):
SELF_HEAL_COOLDOWN_MIN=30
# per-platform per-day cap, then escalate to a human:
SELF_HEAL_MAX_ATTEMPTS=6
# max simultaneous self-heal repairs fleet-wide:
SELF_HEAL_MAX_CONCURRENT=2
