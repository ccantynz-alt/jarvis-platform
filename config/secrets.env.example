# JARVIS PLATFORM — SECRETS
# Copy to: /opt/jarvis/config/secrets.env
# chmod 600 /opt/jarvis/config/secrets.env
# Never commit the real secrets.env file

# Slack (get from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-YOUR-TOKEN-HERE        # Bot User OAuth Token (already set)
SLACK_APP_TOKEN=xapp-YOUR-APP-TOKEN-HERE    # App-Level Token for Socket Mode
# To generate SLACK_APP_TOKEN:
#   1. api.slack.com/apps → Your App → Socket Mode → Enable
#   2. App-Level Tokens → Generate Token → name it "jarvis-socket" → scope: connections:write
#   3. Copy the xapp-... value here, then: systemctl restart jarvis-slack
JARVIS_SLACK_CHANNEL=#jarvis

# Anthropic Messages API key (metered, NOT the claude.ai subscription login
# used by spawn-agent.js workers / the primary brain — see CLAUDE.md's "THE
# ELEVEN SERVICES" note on brain-claude.js). Optional/fallback-only, THREE uses:
#   1. slack-bridge.js's Haiku intent classifier — ~300ms instead of the
#      3-10s claude-CLI cold start (falls back to the CLI without this key).
#   2. lib/agent.js's 'anthropic' provider — an emergency fallback brain if
#      the subscription session (provider 'claude') is unavailable.
#   3. lib/conversation.js's classifyIntent() Haiku fast-path — same ~300ms
#      win as #1, but for the Gateway/voice brain's own (separate) intent
#      classifier. Falls back to its own CLI path automatically without this.
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# Notification tuning (all optional — defaults shown)
JARVIS_DIGEST_MINUTES=30              # how often batched (info-level) updates flush as one digest
JARVIS_NOTIFY_COOLDOWN_MINUTES=30     # same alert key can't repeat within this window
JARVIS_MAX_IMMEDIATE_PER_HOUR=15      # rate-limit backstop; overflow goes to the digest
JARVIS_QUIET_HOURS=22-7               # NZ hours when non-critical is held; "off" to disable

# This machine's own IP, as it appears in config/platforms.json's "server"
# field — lets orchestrator.js tell local vs remote platforms apart.
# Set this per-machine (primary vs standby use different values).
OWN_IP=66.42.121.161

# Chromium binary (auto-detected by install.sh)
CHROMIUM_BIN=chromium-browser

# Platform repo paths on this server
ZOOBICON_PATH=/var/www/zoobicon
VAPRON_PATH=/var/www/vapron
ALECRAE_PATH=/var/www/alecrae
GATETEST_PATH=/var/www/gatetest

# Gateway (docs/GATEWAY.md)
JARVIS_GATEWAY_TOKEN=
NOTIFY_SLACK_LEGACY=1
