# JARVIS PLATFORM — SECRETS
# Copy to: /opt/jarvis/config/secrets.env
# chmod 600 /opt/jarvis/config/secrets.env
# Never commit the real secrets.env file

# Slack (get from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-YOUR-TOKEN-HERE        # Bot User OAuth Token (already set)
SLACK_APP_TOKEN=xapp-YOUR-APP-TOKEN-HERE    # App-Level Token for Socket Mode
# To generate SLACK_APP_TOKEN:
#   1. api.slack.com/apps → Your App → Socket Mode → Enable
#   2. App-Level Tokens → Generate Token → name it "jarvis-socket" → scope: connections:write
#   3. Copy the xapp-... value here, then: systemctl restart jarvis-slack
JARVIS_SLACK_CHANNEL=#jarvis

# This machine's own IP, as it appears in config/platforms.json's "server"
# field — lets orchestrator.js tell local vs remote platforms apart.
# Set this per-machine (primary vs standby use different values).
OWN_IP=66.42.121.161

# Chromium binary (auto-detected by install.sh)
CHROMIUM_BIN=chromium-browser

# Platform repo paths on this server
ZOOBICON_PATH=/var/www/zoobicon
VAPRON_PATH=/var/www/vapron
ALECRAE_PATH=/var/www/alecrae
GATETEST_PATH=/var/www/gatetest
